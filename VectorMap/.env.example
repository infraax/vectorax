# ─── VectorMap — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# The application loads these at startup via python-dotenv (optional).

# ─── Server ───────────────────────────────────────────────────────────────────
# Port to bind the FastAPI server on (0 = auto-assign a free port)
PORT=0

# ─── Ollama ───────────────────────────────────────────────────────────────────
# Base URL for your local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Default LLM model to use for agent queries
OLLAMA_MODEL=qwen2.5-coder:7b

# ─── Data Paths ───────────────────────────────────────────────────────────────
# Override the default relative paths if you keep your data elsewhere.
# Leave blank to use the defaults (data/ subdirectory inside the project).

# Path to your Obsidian markdown vault
# VAULT_DIR=/path/to/your/obsidian/vault

# Path to the ChromaDB persistent storage directory
# DB_DIR=/path/to/your/chroma_db

# ─── Agent Config ─────────────────────────────────────────────────────────────
# Number of context chunks retrieved per query (default: 8)
RETRIEVAL_K=8

# Max LLM retries on hallucination detection (default: 3)
MAX_ATTEMPTS=3

# Token budget for context window (default: 20000)
CONTEXT_BUDGET=20000
